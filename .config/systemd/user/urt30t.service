[Unit]
Description=UrT 4.3 Game/Discord Bot
AssertPathExists=%h/urt30t
After=urt43.service

[Install]
WantedBy=default.target

[Service]
Type=exec
Restart=on-failure
RestartSec=3
EnvironmentFile=%h/.config/urt30t/env.ts
WorkingDirectory=%h/urt30t
ExecStart=taskset -c 2 %h/urt30t/.venv/bin/python -m urt30t
