[Unit]
Description=UrT 4.3 B3 Bot
After=urt43.service
StartLimitIntervalSec=120
StartLimitBurst=20

[Install]
WantedBy=multi-user.target

[Service]
Type=exec
CPUAffinity=1-2
Environment=UV_COMPILE_BYTECODE=1 UV_NO_DEV=1 UV_FROZEN=1 PYTHONUNBUFFERED=1
WorkingDirectory=%h/b3
ExecStartPre=-git pull
ExecStartPre=-%h/.local/bin/uv sync
ExecStart=%h/b3/.venv/bin/python -m b3 -c %h/.config/b3.ini
TimeoutSec=300
Restart=on-failure
RestartSec=5
LimitNOFILE=5000
