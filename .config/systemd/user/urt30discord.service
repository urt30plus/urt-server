[Unit]
Description=UrT 4.3 Discord Bot
After=urt43.service

[Install]
WantedBy=default.target

[Service]
Type=exec
CPUAffinity=1-2
Environment=UV_COMPILE_BYTECODE=1 UV_NO_DEV=1 UV_FROZEN=1 PYTHONUNBUFFERED=1
WorkingDirectory=%h/urt30discord
ExecStartPre=-git pull
ExecStart=%h/.local/bin/uv run -m urt30discord %h/.config/urt30discord.toml
Restart=on-failure
RestartSec=5
RestartSteps=5
RestartMaxDelaySec=30
