# 30plus B3 systemd service file

[Unit]
Description=UrT 4.3 B3 CTF
After=network.target urt43_ctf.service

[Install]
WantedBy=multi-user.target

[Service]
User=urtadmin
Group=urtadmin
PIDFile=/game/run/b3_ctf.pid
ExecStart=/game/bin/b3.sh ctf
ExecStop=/game/bin/b3.sh ctf stop
TimeoutSec=600
Restart=on-failure
LimitNOFILE=5000
